---
// Renders one glyph from the central set (src/lib/icons.ts). Size and visibility
// come from the caller via `class` (e.g. "h-4 w-4", or a toggle's state-variant
// classes like "dark:hidden").
import { ICONS, type IconName } from "../lib/icons";

interface Props {
  name: IconName;
  class?: string;
}
const { name, class: cls } = Astro.props;
const icon = ICONS[name];
---

<svg
  class={cls}
  viewBox={icon.viewBox}
  fill={icon.fill}
  stroke={icon.stroke}
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={icon.body}
/>
