---
// The two "add this deadline to your calendar" icons, shown before a single
// paper/abstract deadline row. Each adds only that date. Both are outline
// (stroke) glyphs from the same Feather family as the toolbar icons:
//   - calendar-with-plus  -> add to Google Calendar
//   - download            -> download the .ics file
import type { DeadlineItem } from "../lib/deadlines";

interface Props {
  item: DeadlineItem;
}
const { item } = Astro.props;
const label = item.kind; // "paper" | "abstract"
const iconCls =
  "rounded p-0.5 text-text-3 transition-colors hover:bg-[rgba(120,120,140,0.14)] hover:text-accent dark:hover:bg-[rgba(255,255,255,0.07)]";
const svgCls = "h-3.5 w-3.5";
---

<a
  href={item.gcalUrl}
  target="_blank"
  rel="noopener"
  title={`Add ${label} deadline to Google Calendar`}
  aria-label={`Add ${label} deadline to Google Calendar`}
  class={iconCls}
>
  <svg class={svgCls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 2v3M16 2v3M3.5 9h17M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z" />
    <path d="M12 13.5v3.5M10.25 15.25h3.5" />
  </svg>
</a>
<a
  href={item.icsHref}
  download={`${item.uid}.ics`}
  title={`Download ${label} deadline (.ics)`}
  aria-label={`Download ${label} deadline (.ics)`}
  class={iconCls}
>
  <svg class={svgCls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
    <path d="m7 10 5 5 5-5" />
    <path d="M12 15V3" />
  </svg>
</a>
