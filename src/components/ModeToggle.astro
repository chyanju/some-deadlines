---
// Detail-level toggle — a stateful icon button. "complex" (default) shows the
// inline per-deadline countdowns; "simple" hides them, leaving just the big
// figure. Wired by scripts/mode.ts; the active mode shows via the `simple` class
// on <html> (telescope = complex/detailed, bird = simple).
---

<button
  type="button"
  data-mode-toggle
  class="tbar-icon"
  aria-label="Toggle detail (simple / complex)"
  title="Detail: simple / complex"
>
  {/* complex (detailed) = telescope */}
  <svg class="h-[18px] w-[18px] simple:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m10.065 12.493-6.18 1.318a.934.934 0 0 1-1.108-.702l-.537-2.15a1.07 1.07 0 0 1 .691-1.265l13.504-4.44"></path><path d="m13.56 11.747 4.332-.924"></path><path d="m16 21-3.105-6.21"></path><path d="M16.485 5.94a2 2 0 0 1 1.455-2.425l1.09-.272a1 1 0 0 1 1.212.727l1.515 6.06a1 1 0 0 1-.727 1.213l-1.09.272a2 2 0 0 1-2.425-1.455z"></path><path d="m6.158 8.633 1.114 4.456"></path><path d="m8 21 3.105-6.21"></path><circle cx="12" cy="13" r="2"></circle></svg>
  {/* simple = bird */}
  <svg class="hidden h-[18px] w-[18px] simple:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 7h.01"></path><path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"></path><path d="m20 7 2 .5-2 .5"></path><path d="M10 18v3"></path><path d="M14 17.75V21"></path><path d="M7 18a6 6 0 0 0 3.84-10.61"></path></svg>
</button>
