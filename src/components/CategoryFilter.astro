---
import { types } from "../data/conferences";
---

<div class="flex flex-wrap items-center gap-1.5" data-filter>
  {
    types.map((t) => (
      <button
        type="button"
        class="chip"
        data-sub={t.sub}
        style={`--c:${t.color}`}
        aria-pressed="true"
        title={t.name}
      >
        {t.name}
      </button>
    ))
  }
  <span class="mx-1 h-4 w-px bg-border" aria-hidden="true"></span>
  <button
    type="button"
    class="rounded-md px-2 py-1 text-xs text-text-3 transition-colors hover:text-text-2"
    data-filter-all>All</button
  >
  <button
    type="button"
    class="rounded-md px-2 py-1 text-xs text-text-3 transition-colors hover:text-text-2"
    data-filter-clear>None</button
  >
</div>
