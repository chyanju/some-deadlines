---
import { types } from "../data/conferences";
import Icon from "./Icon.astro";

interface Props {
  showPastToggle?: boolean;
}
const { showPastToggle = false } = Astro.props;
---

<div class="relative inline-block text-left" data-filter>
  <button
    type="button"
    data-filter-button
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Options"
    title="Options"
    class="tbar-icon relative"
  >
    <Icon name="sliders" class="h-[18px] w-[18px]" />
    <span
      data-filter-dot
      hidden
      class="absolute top-1 right-1 h-1.5 w-1.5 rounded-full bg-accent"
    ></span>
  </button>

  <div
    data-filter-menu
    hidden
    class="absolute right-0 z-30 mt-2 w-max min-w-[12rem] rounded-[14px] border border-border bg-card p-2 shadow-lg"
  >
    <div class="max-h-80 overflow-auto">
      <div class="eyebrow px-2.5 pb-1">Categories</div>
      {
        types.map((t) => (
          <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
            <input
              type="checkbox"
              data-sub={t.sub}
              class="size-3.5 accent-[var(--color-accent)]"
            />
            <span
              class="inline-block size-2 shrink-0 rounded-full"
              style={`background:${t.color}`}
            />
            <span>{t.name}</span>
          </label>
        ))
      }
      <div class="mt-0.5 flex justify-end gap-3 px-2.5 pt-1 text-xs">
        <button type="button" data-filter-all class="text-text-3 transition-colors hover:text-text-2">Select All</button>
        <button type="button" data-filter-clear class="text-text-3 transition-colors hover:text-text-2">Clear</button>
      </div>
      {
        showPastToggle && (
          <>
            <div class="my-1.5 h-px bg-border" />
            <div class="eyebrow px-2.5 pb-1">Show</div>
            <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
              <input
                type="checkbox"
                data-show-past
                class="size-3.5 accent-[var(--color-accent)]"
              />
              <span>Include Closed Deadlines</span>
            </label>
          </>
        )
      }
    </div>
    <div class="mt-1 border-t border-border pt-1.5">
      <div class="eyebrow px-2.5 pb-1">Sort By</div>
      <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
        <input type="radio" name="sort-mode" data-sort="deadline" class="size-3.5 accent-[var(--color-accent)]" />
        <span>Submission Deadline</span>
      </label>
      <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
        <input type="radio" name="sort-mode" data-sort="milestone" class="size-3.5 accent-[var(--color-accent)]" />
        <span>Nearest Milestone</span>
      </label>
    </div>
  </div>
</div>
