---
import { types } from "../data/conferences";

interface Props {
  showPastToggle?: boolean;
}
const { showPastToggle = false } = Astro.props;
---

<div class="relative inline-block text-left" data-filter>
  <button
    type="button"
    data-filter-button
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Filter categories"
    title="Filter"
    class="tbar-icon relative"
  >
    <svg
      class="h-[18px] w-[18px]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M3 5h18M6 12h12M10 19h4"></path>
    </svg>
    <span
      data-filter-dot
      hidden
      class="absolute top-1 right-1 h-1.5 w-1.5 rounded-full bg-accent"
    ></span>
  </button>

  <div
    data-filter-menu
    hidden
    class="absolute right-0 z-30 mt-2 w-max min-w-[12rem] rounded-[14px] border border-border bg-card p-2 shadow-lg"
  >
    <div class="max-h-80 overflow-auto">
      {
        types.map((t) => (
          <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
            <input
              type="checkbox"
              data-sub={t.sub}
              class="size-3.5 accent-[var(--color-accent)]"
            />
            <span
              class="inline-block size-2 shrink-0 rounded-full"
              style={`background:${t.color}`}
            />
            <span>{t.name}</span>
          </label>
        ))
      }
      {
        showPastToggle && (
          <>
            <div class="my-1 h-px bg-border" />
            <label class="menu-row flex cursor-pointer items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm whitespace-nowrap text-text">
              <input
                type="checkbox"
                data-show-past
                class="size-3.5 accent-[var(--color-accent)]"
              />
              <span>Closed submissions</span>
            </label>
          </>
        )
      }
    </div>
    <div
      class="mt-1 flex justify-between border-t border-border px-2 pt-1.5 text-xs"
    >
      <button
        type="button"
        data-filter-all
        class="text-text-3 transition-colors hover:text-text-2">Select all</button
      >
      <button
        type="button"
        data-filter-clear
        class="text-text-3 transition-colors hover:text-text-2">Clear</button
      >
    </div>
  </div>
</div>
