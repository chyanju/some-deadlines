---
import { site } from "../data/site";
---

<footer class="border-t border-border py-10 text-center text-sm text-text-3">
  <p class="px-4">
    <span class="font-display">{site.title}</span> · adapted from{" "}
    <a
      class="transition-colors hover:text-text-2"
      href="https://github.com/paperswithcode/ai-deadlines"
      target="_blank"
      rel="noopener">ai-deadlines</a
    >
    {
      site.githubRepo && (
        <>
          {" · "}
          <a
            class="transition-colors hover:text-text-2"
            href={`https://github.com/${site.githubRepo}`}
            target="_blank"
            rel="noopener"
          >
            source
          </a>
        </>
      )
    }
  </p>
</footer>
