---
// Local / AoE deadline time-zone toggle. Wired by src/scripts/tz.ts.
---

<div
  class="inline-flex items-center rounded-md border border-border p-0.5 text-xs"
  role="group"
  aria-label="Deadline time zone"
  data-tz-toggle
>
  <button type="button" data-tz="local" class="px-2 py-1">Local</button>
  <button type="button" data-tz="aoe" class="px-2 py-1">AoE</button>
</div>
