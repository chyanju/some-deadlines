---
import type { ProcessedConference } from "../lib/deadlines";

interface Props {
  conf: ProcessedConference;
}
const { conf } = Astro.props;
---

<article
  id={conf.id}
  data-conf
  data-deadline={conf.deadlineMs ?? ""}
  data-subs={conf.subs.join(",")}
  class="card flex items-center gap-4 p-5"
>
  <div class="min-w-0 flex-1">
    <h2
      class="font-display text-[1.25rem] font-[520] leading-tight tracking-[-0.012em] text-text"
    >
      <a
        href={`/conference/${conf.id}/`}
        class="transition-colors hover:text-accent"
      >
        {conf.title}
        {conf.year}
      </a>
      <a
        href={conf.link}
        target="_blank"
        rel="noopener"
        title="Conference website"
        class="ml-0.5 inline-block align-middle text-text-3 transition-colors hover:text-accent"
        aria-label="Conference website"
      >
        <svg
          class="inline h-3.5 w-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17 17 7M9 7h8v8"></path>
        </svg>
      </a>
    </h2>

    <div class="mt-1.5 flex flex-wrap items-center gap-1.5">
      {
        conf.categories.map((t) => (
          <span class="badge" style={`--c:${t.color}`} title={t.name}>
            {t.sub}
          </span>
        ))
      }
    </div>

    <p class="mt-2 text-[0.9375rem] text-text-2">
      {conf.date} · {conf.place}
    </p>
  </div>

  <div class="w-24 shrink-0 text-right">
    <div class="cd-eyebrow eyebrow">days left</div>
    <div
      data-cd-days
      class="tnum font-mono text-[2rem] leading-none font-semibold text-text"
    >
      —
    </div>
    <div data-cd-clock class="tnum mt-1 font-mono text-[0.8125rem] text-text-3">
      &nbsp;
    </div>
  </div>
</article>
