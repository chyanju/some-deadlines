---
import type { ProcessedConference } from "../lib/deadlines";
import { deadlineItems, abbrevMonths } from "../lib/deadlines";
import DeadlineActions from "./DeadlineActions.astro";
import InlineCountdown from "./InlineCountdown.astro";
import Icon from "./Icon.astro";

interface Props {
  conf: ProcessedConference;
}
const { conf } = Astro.props;

// Add-to-calendar actions, keyed by milestone so each row can find its own.
const actionByKey = new Map(deadlineItems(conf).map((d) => [d.kind, d]));

// Milestone rows in chronological order: by Anywhere-on-Earth day, then the
// registry phase for same-day milestones (e.g. ASE's early reject before its
// rebuttal). Paper is always shown (even TBA); the rest only when dated.
const aoeDay = (ms: number | null) =>
  ms == null ? Infinity : Math.floor((ms - 12 * 3_600_000) / 86_400_000);
const rows = conf.milestones
  .filter((m) => m.always || m.short)
  .sort((a, b) => aoeDay(a.ms) - aoeDay(b.ms) || a.phase - b.phase)
  .map((m) => ({ m, action: actionByKey.get(m.key) }));

const iconCls = "icon-link shrink-0 rounded p-1";
---

<article
  id={conf.id}
  data-conf
  data-deadline={conf.deadlineMs ?? ""}
  data-subs={conf.subs.join(",")}
  style={`--c:${conf.categories[0]?.color ?? "var(--color-border-strong)"}`}
  class="card p-5"
>
  {/* Row 1 — title + website link (left), category labels (right) */}
  <div class="flex items-center justify-between gap-3">
    <div class="flex min-w-0 items-center gap-x-1">
      <h2
        class="truncate font-display text-[1.25rem] leading-tight font-[560] tracking-[-0.012em] text-text"
      >
        {conf.title}
        {conf.year}
      </h2>
      <a href={conf.link} target="_blank" rel="noopener" title="Conference website" aria-label="Conference website" class={iconCls}>
        <Icon name="external-link" class="h-4 w-4" />
      </a>
    </div>

    <div class="flex shrink-0 flex-wrap justify-end gap-1.5">
      {
        conf.categories.map((t) => (
          <span class="badge" style={`--c:${t.color}`}>
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  {/* Row 2 — date·place + milestone mini-table (icons · label · date · countdown),
      with the big countdown (the focus) to the right. On phones the big figure
      stacks on top and each milestone row reflows (flex-wrap) so a long date never
      breaks mid-value; ≥640px the rows align as a 4-column grid. */}
  <div
    class="mt-2.5 flex flex-col-reverse gap-3 sm:flex-row sm:items-end sm:justify-between sm:gap-4"
  >
    <div class="min-w-0 flex-1">
      <dl class="dl-grid text-[0.8125rem]">
        <div class="dl-row dl-row-conf">
          <span class="dl-conf-text text-text-2">{abbrevMonths(conf.date)} · {conf.place}</span>
          <InlineCountdown ms={conf.startMs} endMs={conf.endMs} />
        </div>
        {
          rows.map(({ m, action }) => (
            <div class="dl-row">
              <span class="dl-actions flex min-w-[2.4rem] items-center gap-0.5">
                {action && <DeadlineActions item={action} />}
              </span>
              <dt class="dl-label eyebrow">{m.label}</dt>
              <dd class={`dl-date tnum ${m.strong ? "text-text" : "text-text-2"}`}>
                <span data-dl={m.ms ?? ""}>{m.short ?? "TBA"}</span>
              </dd>
              <InlineCountdown ms={m.ms} endMs={m.endMs} />
            </div>
          ))
        }
      </dl>
    </div>

    {/* Big countdown: number on the left, "days left" over the live clock on the right. */}
    <div class="shrink-0 flex items-center gap-2">
      <span data-cd-days class="tnum text-[2.25rem] leading-none font-bold text-text-2">—</span>
      <div class="flex flex-col gap-1 text-left leading-none">
        <span class="cd-eyebrow eyebrow">days left</span>
        <span data-cd-clock class="tnum text-[0.8125rem] font-semibold text-text-2">&nbsp;</span>
      </div>
    </div>
  </div>
</article>
