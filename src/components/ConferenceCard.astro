---
import type { ProcessedConference } from "../lib/deadlines";
import { gcalEventUrl } from "../lib/deadlines";

interface Props {
  conf: ProcessedConference;
}
const { conf } = Astro.props;
const gcal = gcalEventUrl(conf);
const maps =
  conf.place === "Online"
    ? null
    : `https://maps.google.com/?q=${encodeURIComponent(conf.place)}`;
---

<article
  id={conf.id}
  data-conf
  data-deadline={conf.deadlineMs ?? ""}
  data-subs={conf.subs.join(",")}
  class="card"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h2 class="text-lg font-semibold text-gray-900">
        <a href={`/conference/${conf.id}/`} class="hover:underline">
          {conf.title}
          {conf.year}
        </a>
        <a
          href={conf.link}
          target="_blank"
          rel="noopener"
          title="Conference website"
          class="ml-0.5 text-gray-400 hover:text-gray-600">↗</a
        >
      </h2>
      <div class="mt-1 flex flex-wrap gap-1">
        {
          conf.categories.map((t) => (
            <span class="badge" style={`--c:${t.color}`} title={t.name}>
              {t.sub}
            </span>
          ))
        }
      </div>
    </div>
    <div class="shrink-0 text-right">
      <div
        data-countdown
        class="font-mono text-lg font-bold tabular-nums text-gray-900 sm:text-xl"
      >
        —
      </div>
    </div>
  </div>

  <div class="mt-3 grid gap-3 text-sm sm:grid-cols-2">
    <div class="text-gray-600">
      <p>{conf.date}</p>
      <p>
        {
          maps ? (
            <a href={maps} target="_blank" rel="noopener" class="hover:underline">
              {conf.place}
            </a>
          ) : (
            <span>{conf.place}</span>
          )
        }
      </p>
      {conf.note && <p class="mt-1 text-gray-500" set:html={conf.note} />}
    </div>
    <div class="space-y-1 text-gray-600">
      <div>
        <div class="text-xs text-gray-400">Paper deadline (your time)</div>
        <div data-local class="text-gray-800">
          {conf.deadlineInConfTz ?? "TBA"}
        </div>
        {
          conf.deadlineInConfTz && (
            <div class="text-xs text-gray-400">{conf.deadlineInConfTz}</div>
          )
        }
      </div>
      {
        conf.absInConfTz && (
          <div>
            <div class="text-xs text-gray-400">Abstract deadline</div>
            <div class="text-xs text-gray-500">{conf.absInConfTz}</div>
          </div>
        )
      }
      {
        gcal && (
          <a
            href={gcal}
            target="_blank"
            rel="noopener"
            class="inline-block text-xs text-blue-600 hover:underline"
          >
            + Add to Google Calendar
          </a>
        )
      }
    </div>
  </div>
</article>
