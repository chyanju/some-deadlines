---
import type { ProcessedConference, DeadlineItem } from "../lib/deadlines";
import { deadlineItems, abbrevMonths } from "../lib/deadlines";
import DeadlineActions from "./DeadlineActions.astro";
import InlineCountdown from "./InlineCountdown.astro";

interface Props {
  conf: ProcessedConference;
}
const { conf } = Astro.props;
const items = deadlineItems(conf);
const find = (k: DeadlineItem["kind"]) => items.find((d) => d.kind === k);

// Every present milestone as a row, sorted chronologically: by Anywhere-on-Earth
// day, then a canonical phase order for same-day milestones (e.g. ASE's early
// reject and rebuttal both fall on one day). Paper is always shown (even TBA) and
// stays emphasised; rebuttal carries its window end.
interface Row {
  key: DeadlineItem["kind"];
  label: string;
  ms: number | null;
  endMs: number | null;
  short: string;
  item?: DeadlineItem;
  strong?: boolean;
}
const rows: Row[] = [
  { key: "paper", label: "Paper", ms: conf.deadlineMs, endMs: null, short: conf.deadlineShort ?? "TBA", item: find("paper"), strong: true },
];
if (conf.absShort) rows.push({ key: "abstract", label: "Abstract", ms: conf.absDeadlineMs, endMs: null, short: conf.absShort, item: find("abstract") });
if (conf.earlyRejectShort) rows.push({ key: "early-reject", label: "Early Reject", ms: conf.earlyRejectMs, endMs: null, short: conf.earlyRejectShort, item: find("early-reject") });
if (conf.rebuttalShort) rows.push({ key: "rebuttal", label: "Rebuttal", ms: conf.rebuttalStartMs, endMs: conf.rebuttalEndMs, short: conf.rebuttalShort, item: find("rebuttal") });
if (conf.notificationShort) rows.push({ key: "notification", label: "Notification", ms: conf.notificationMs, endMs: null, short: conf.notificationShort, item: find("notification") });
const PHASE: Record<DeadlineItem["kind"], number> = { abstract: 0, paper: 1, "early-reject": 2, rebuttal: 3, notification: 4 };
const aoeDay = (ms: number | null) => (ms == null ? Infinity : Math.floor((ms - 12 * 3_600_000) / 86_400_000));
rows.sort((a, b) => aoeDay(a.ms) - aoeDay(b.ms) || PHASE[a.key] - PHASE[b.key]);
const iconCls =
  "shrink-0 rounded p-1 text-text-3 transition-colors hover:bg-[rgba(120,120,140,0.14)] hover:text-accent dark:hover:bg-[rgba(255,255,255,0.07)]";
---

<article
  id={conf.id}
  data-conf
  data-deadline={conf.deadlineMs ?? ""}
  data-abs={conf.absDeadlineMs ?? ""}
  data-er={conf.earlyRejectMs ?? ""}
  data-rstart={conf.rebuttalStartMs ?? ""}
  data-rend={conf.rebuttalEndMs ?? ""}
  data-notif={conf.notificationMs ?? ""}
  data-start={conf.startMs ?? ""}
  data-end={conf.endMs ?? ""}
  data-subs={conf.subs.join(",")}
  style={`--c:${conf.categories[0]?.color ?? "var(--color-border-strong)"}`}
  class="card p-5"
>
  {/* Row 1 — title + website link (left), category labels (right) */}
  <div class="flex items-center justify-between gap-3">
    <div class="flex min-w-0 items-center gap-x-1">
      <h2
        class="truncate font-display text-[1.25rem] leading-tight font-[560] tracking-[-0.012em] text-text"
      >
        {conf.title}
        {conf.year}
      </h2>
      <a href={conf.link} target="_blank" rel="noopener" title="Conference website" aria-label="Conference website" class={iconCls}>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 3h6v6" />
          <path d="M10 14 21 3" />
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
        </svg>
      </a>
    </div>

    <div class="flex shrink-0 flex-wrap justify-end gap-1.5">
      {
        conf.categories.map((t) => (
          <span class="badge" style={`--c:${t.color}`}>
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  {/* Row 2 — date·place, then a per-deadline mini-table (icons · label · date ·
      countdown) with aligned columns; the big paper countdown (the focus) sits on
      the right. */}
  <div class="mt-2.5 flex items-end justify-between gap-4">
    <div class="min-w-0 flex-1">
      <dl class="dl-grid mt-0.5 text-[0.8125rem]">
        <div class="contents">
          <span class="dl-conf text-text-2">{abbrevMonths(conf.date)} · {conf.place}</span>
          <InlineCountdown ms={conf.startMs} endMs={conf.endMs} />
        </div>
        {
          rows.map((m) => (
            <div class="contents">
              <span class="flex min-w-[2.4rem] items-center gap-0.5">
                {m.item && <DeadlineActions item={m.item} />}
              </span>
              <dt class="eyebrow">{m.label}</dt>
              <dd class={`tnum ${m.strong ? "text-text" : "text-text-2"}`}>
                <span data-dl={m.ms ?? ""}>{m.short}</span>
              </dd>
              <InlineCountdown ms={m.ms} endMs={m.endMs} />
            </div>
          ))
        }
      </dl>
    </div>

    {/* Big paper countdown: number on the left (spans two rows), "days left" over
        the live clock on the right. */}
    <div class="shrink-0 flex items-center gap-2">
      <span data-cd-days class="tnum text-[2.25rem] leading-none font-bold text-text-2">—</span>
      <div class="flex flex-col gap-1 text-left leading-none">
        <span class="cd-eyebrow eyebrow">days left</span>
        <span data-cd-clock class="tnum text-[0.8125rem] font-semibold text-text-2">&nbsp;</span>
      </div>
    </div>
  </div>
</article>
