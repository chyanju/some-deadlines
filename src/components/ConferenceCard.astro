---
import type { ProcessedConference } from "../lib/deadlines";
import { deadlineItems } from "../lib/deadlines";
import DeadlineActions from "./DeadlineActions.astro";

interface Props {
  conf: ProcessedConference;
}
const { conf } = Astro.props;
const items = deadlineItems(conf);
const paper = items.find((d) => d.kind === "paper");
const abstract = items.find((d) => d.kind === "abstract");
const iconCls =
  "shrink-0 rounded p-1 text-text-3 transition-colors hover:bg-[rgba(120,120,140,0.14)] hover:text-accent dark:hover:bg-[rgba(255,255,255,0.07)]";
---

<article
  id={conf.id}
  data-conf
  data-deadline={conf.deadlineMs ?? ""}
  data-subs={conf.subs.join(",")}
  style={`--c:${conf.categories[0]?.color ?? "var(--color-border-strong)"}`}
  class="card p-5"
>
  {/* Row 1 — title + website link (left), category labels (right) */}
  <div class="flex items-center justify-between gap-3">
    <div class="flex min-w-0 items-center gap-x-1">
      <h2
        class="truncate font-display text-[1.25rem] leading-tight font-[560] tracking-[-0.012em] text-text"
      >
        {conf.title}
        {conf.year}
      </h2>
      <a href={conf.link} target="_blank" rel="noopener" title="Conference website" aria-label="Conference website" class={iconCls}>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
      </a>
    </div>

    <div class="flex shrink-0 flex-wrap justify-end gap-1.5">
      {
        conf.categories.map((t) => (
          <span class="badge" style={`--c:${t.color}`}>
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  {/* Row 2 — dates + per-deadline rows w/ their own add-to-calendar icons (left),
      countdown (right, dropped down) */}
  <div class="mt-2.5 flex items-end justify-between gap-4">
    <div class="min-w-0 flex-1">
      <p class="text-[0.9375rem] text-text-2">{conf.date} · {conf.place}</p>
      <dl class="mt-1 space-y-1 text-[0.8125rem]">
        <div class="flex items-center gap-2">
          <span class="flex min-w-[2.4rem] shrink-0 items-center gap-0.5">
            {paper && <DeadlineActions item={paper} />}
          </span>
          <dt class="eyebrow w-16 shrink-0">Paper</dt>
          <dd class="tnum text-text" data-dl={conf.deadlineMs ?? ""}>
            {conf.deadlineShort ?? "TBA"}
          </dd>
        </div>
        {
          conf.absShort && (
            <div class="flex items-center gap-2">
              <span class="flex min-w-[2.4rem] shrink-0 items-center gap-0.5">
                {abstract && <DeadlineActions item={abstract} />}
              </span>
              <dt class="eyebrow w-16 shrink-0">Abstract</dt>
              <dd class="tnum text-text-2" data-dl={conf.absDeadlineMs ?? ""}>
                {conf.absShort}
              </dd>
            </div>
          )
        }
      </dl>
    </div>

    <div class="shrink-0 text-right leading-none">
      <span class="cd-eyebrow eyebrow">days left</span>
      <div class="flex items-baseline justify-end gap-1.5">
        <span data-cd-days class="tnum text-[2rem] leading-none font-semibold text-text">—</span>
        <span data-cd-clock class="tnum text-[0.8125rem] text-text-3">&nbsp;</span>
      </div>
    </div>
  </div>
</article>
