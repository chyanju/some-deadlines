---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import IconToggle from "./IconToggle.astro";
---

<header class="sticky top-0 z-30 px-3 py-2 sm:px-4">
  <div
    class="mx-auto flex max-w-3xl flex-wrap items-center gap-x-2 gap-y-2 px-3 py-2.5 sm:gap-x-3 sm:px-4"
  >
    <a
      href={`${import.meta.env.BASE_URL}/`}
      class="shrink-0 font-display text-[1.0625rem] font-[540] tracking-[-0.01em] text-text sm:text-[1.1875rem]"
    >
      {site.title}
    </a>

    {/* All controls right-aligned as one cluster: view · tz · filter · theme */}
    <div class="ml-auto flex flex-wrap items-center gap-1 sm:gap-2">
      <slot name="toolbar" />

      {/* Light shows the sun; dark shows the moon (current state). */}
      <IconToggle
        toggle="theme"
        iconInactive="sun"
        iconActive="moon"
        label="Toggle dark mode"
        title="Toggle theme"
      />

      {
        site.githubRepo && (
          <a
            href={`https://github.com/${site.githubRepo}`}
            target="_blank"
            rel="noopener"
            aria-label="GitHub repository"
            title="GitHub"
            class="tbar-icon"
          >
            <Icon name="github" class="h-[18px] w-[18px]" />
          </a>
        )
      }
    </div>
  </div>
</header>
