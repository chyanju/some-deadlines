---
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<header class="sticky top-0 z-30 py-2">
  <div
    class="mx-auto flex max-w-3xl flex-wrap items-center gap-x-3 gap-y-2 px-4 py-2.5"
  >
    <a
      href="/"
      class="shrink-0 font-display text-[1.1875rem] font-[540] tracking-[-0.01em] text-text"
    >
      {site.title}
    </a>

    {/* All controls right-aligned as one cluster: view · tz · filter · theme */}
    <div class="ml-auto flex flex-wrap items-center gap-2">
      <slot name="toolbar" />

      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        title="Toggle theme"
        class="tbar-icon"
      >
        {/* Light mode shows the sun; dark mode shows the moon (current state). */}
        <svg
          class="h-[18px] w-[18px] dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
        <svg
          class="hidden h-[18px] w-[18px] dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      {
        site.githubRepo && (
          <a
            href={`https://github.com/${site.githubRepo}`}
            target="_blank"
            rel="noopener"
            aria-label="GitHub repository"
            title="GitHub"
            class="tbar-icon"
          >
            <Icon name="github" class="h-[18px] w-[18px]" />
          </a>
        )
      }
    </div>
  </div>
</header>
