---
import Layout from "../../layouts/Layout.astro";
import { allConferences, gcalEventUrl } from "../../lib/deadlines";
import type { ProcessedConference } from "../../lib/deadlines";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() =>
  allConferences.map((c) => ({
    params: { id: c.id },
    props: { conf: c },
  }))) satisfies GetStaticPaths;

const { conf } = Astro.props as { conf: ProcessedConference };
const gcal = gcalEventUrl(conf);
const maps =
  conf.place === "Online"
    ? null
    : `https://maps.google.com/?q=${encodeURIComponent(conf.place)}`;
---

<Layout title={`${conf.title} ${conf.year}`}>
  <a
    href="/"
    class="text-sm text-gray-500 hover:underline dark:text-gray-400"
    >← all deadlines</a
  >

  <header class="mt-3">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      {conf.title}
      {conf.year}
    </h1>
    {
      conf.full_name && (
        <p class="mt-1 text-lg text-gray-500 dark:text-gray-400">
          {conf.full_name}
        </p>
      )
    }
    <div class="mt-2 flex flex-wrap gap-1">
      {
        conf.categories.map((t) => (
          <span class="badge" style={`--c:${t.color}`} title={t.name}>
            {t.name}
          </span>
        ))
      }
    </div>
  </header>

  <dl class="mt-6 grid gap-x-6 gap-y-2 text-sm sm:grid-cols-[max-content_1fr]">
    <dt class="text-gray-400 dark:text-gray-500">Dates</dt>
    <dd class="text-gray-700 dark:text-gray-300">{conf.date}</dd>

    <dt class="text-gray-400 dark:text-gray-500">Place</dt>
    <dd class="text-gray-700 dark:text-gray-300">
      {
        maps ? (
          <a href={maps} target="_blank" rel="noopener" class="hover:underline">
            {conf.place}
          </a>
        ) : (
          conf.place
        )
      }
    </dd>

    <dt class="text-gray-400 dark:text-gray-500">Website</dt>
    <dd>
      <a
        href={conf.link}
        target="_blank"
        rel="noopener"
        class="text-blue-600 hover:underline dark:text-blue-400">{conf.link}</a
      >
    </dd>

    {
      conf.paperslink && (
        <>
          <dt class="text-gray-400 dark:text-gray-500">Accepted papers</dt>
          <dd>
            <a
              href={conf.paperslink}
              target="_blank"
              rel="noopener"
              class="text-blue-600 hover:underline dark:text-blue-400"
            >
              {conf.paperslink}
            </a>
          </dd>
        </>
      )
    }
    {
      conf.pwclink && (
        <>
          <dt class="text-gray-400 dark:text-gray-500">Papers with Code</dt>
          <dd>
            <a
              href={conf.pwclink}
              target="_blank"
              rel="noopener"
              class="text-blue-600 hover:underline dark:text-blue-400"
            >
              {conf.pwclink}
            </a>
          </dd>
        </>
      )
    }
  </dl>

  <section
    class="mt-8 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-colors dark:border-gray-800 dark:bg-gray-900"
  >
    <div
      data-countdown
      data-deadline={conf.deadlineMs ?? ""}
      class="font-mono text-2xl font-bold tabular-nums text-gray-900 sm:text-3xl dark:text-gray-100"
    >
      —
    </div>
    <div class="mt-4 space-y-4 text-sm">
      <div>
        <div class="text-gray-400 dark:text-gray-500">
          Paper deadline — conference timezone
        </div>
        <div class="text-gray-800 dark:text-gray-200">
          {conf.deadlineInConfTz ?? "TBA"}
        </div>
        <div class="mt-1 text-gray-400 dark:text-gray-500">
          Your local (<span class="local-tz">local</span>) time
        </div>
        <div
          data-local-paper
          data-ms={conf.deadlineMs ?? ""}
          class="text-gray-800 dark:text-gray-200"
        >
          —
        </div>
      </div>
      {
        conf.absInConfTz && (
          <div>
            <div class="text-gray-400 dark:text-gray-500">
              Abstract deadline — conference timezone
            </div>
            <div class="text-gray-800 dark:text-gray-200">{conf.absInConfTz}</div>
            <div class="mt-1 text-gray-400 dark:text-gray-500">
              Your local time
            </div>
            <div
              data-local-abs
              data-ms={conf.absDeadlineMs ?? ""}
              class="text-gray-800 dark:text-gray-200"
            >
              —
            </div>
          </div>
        )
      }
      {
        gcal && (
          <a
            href={gcal}
            target="_blank"
            rel="noopener"
            class="inline-block text-blue-600 hover:underline dark:text-blue-400"
          >
            + Add to Google Calendar
          </a>
        )
      }
    </div>
  </section>
</Layout>

<script>
  import { initConferencePage } from "../../scripts/conf";
  document.addEventListener("astro:page-load", initConferencePage);
</script>
