---
import Layout from "../../layouts/Layout.astro";
import { allConferences, gcalEventUrl } from "../../lib/deadlines";
import type { ProcessedConference } from "../../lib/deadlines";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() =>
  allConferences.map((c) => ({
    params: { id: c.id },
    props: { conf: c },
  }))) satisfies GetStaticPaths;

const { conf } = Astro.props as { conf: ProcessedConference };
const gcal = gcalEventUrl(conf);
const maps =
  conf.place === "Online"
    ? null
    : `https://maps.google.com/?q=${encodeURIComponent(conf.place)}`;
const accentColor = conf.categories[0]?.color ?? "var(--color-border-strong)";

const facts: Array<{ label: string; value: string; href?: string }> = [
  { label: "Dates", value: conf.date },
  { label: "Place", value: conf.place, href: maps ?? undefined },
  { label: "Website", value: conf.link, href: conf.link },
];
if (conf.paperslink)
  facts.push({ label: "Papers", value: conf.paperslink, href: conf.paperslink });
if (conf.pwclink)
  facts.push({ label: "Code", value: conf.pwclink, href: conf.pwclink });
---

<Layout title={`${conf.title} ${conf.year}`}>
  <div class="mx-auto max-w-2xl">
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm text-accent transition-colors hover:underline"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      All deadlines
    </a>

    <header class="mt-5">
      <h1
        class="font-display text-[clamp(2rem,5vw,2.75rem)] leading-[1.08] font-[520] tracking-[-0.022em] text-text"
      >
        {conf.title}
        {conf.year}
      </h1>
      {
        conf.full_name && (
          <p class="mt-2 text-[1.0625rem] text-text-2">{conf.full_name}</p>
        )
      }
      <div class="mt-3 flex flex-wrap gap-1.5">
        {
          conf.categories.map((t) => (
            <span class="badge" style={`--c:${t.color}`} title={t.name}>
              {t.name}
            </span>
          ))
        }
      </div>
    </header>

    {/* Countdown hero */}
    <section
      class="mt-8 rounded-2xl border border-border bg-card p-8 shadow-sm"
      style={`border-top:3px solid ${accentColor}`}
    >
      <div
        data-passed
        hidden
        class="text-center font-display text-[1.75rem] font-[500] text-text-2"
      >
        Deadline passed
      </div>
      <div
        data-countdown
        data-deadline={conf.deadlineMs ?? ""}
        class="flex items-start justify-center gap-2 sm:gap-4"
      >
        {
          [
            { id: "d", label: "days" },
            { id: "h", label: "hrs" },
            { id: "m", label: "min" },
            { id: "s", label: "sec" },
          ].map((seg, i) => (
            <>
              {i > 0 && (
                <div class="font-mono text-[clamp(2rem,6vw,3rem)] leading-none text-text-3">
                  :
                </div>
              )}
              <div class="text-center">
                <div
                  data-cd={seg.id}
                  class={`tnum font-mono text-[clamp(2.5rem,9vw,4rem)] leading-none font-semibold text-text cd-${seg.id}`}
                >
                  —
                </div>
                <div class="eyebrow mt-2">{seg.label}</div>
              </div>
            </>
          ))
        }
      </div>
    </section>

    {/* Deadline details */}
    <div class="mt-6 space-y-4 rounded-2xl border border-border bg-card p-6 shadow-sm">
      <div>
        <div class="eyebrow">Paper deadline · conference time</div>
        <div class="mt-0.5 tnum font-mono text-[0.9375rem] text-text">
          {conf.deadlineInConfTz ?? "TBA"}
        </div>
        <div class="eyebrow mt-2">
          Your local (<span class="local-tz">local</span>) time
        </div>
        <div
          data-local-paper
          data-ms={conf.deadlineMs ?? ""}
          class="mt-0.5 tnum font-mono text-[0.9375rem] text-text"
        >
          —
        </div>
      </div>
      {
        conf.absInConfTz && (
          <div class="border-t border-border pt-4">
            <div class="eyebrow">Abstract deadline · conference time</div>
            <div class="mt-0.5 tnum font-mono text-[0.9375rem] text-text">
              {conf.absInConfTz}
            </div>
            <div class="eyebrow mt-2">Your local time</div>
            <div
              data-local-abs
              data-ms={conf.absDeadlineMs ?? ""}
              class="mt-0.5 tnum font-mono text-[0.9375rem] text-text"
            >
              —
            </div>
          </div>
        )
      }
      {
        gcal && (
          <a
            href={gcal}
            target="_blank"
            rel="noopener"
            class="inline-flex h-9 items-center rounded-md bg-accent px-4 text-sm font-medium text-accent-fg transition hover:brightness-110"
          >
            Add to Google Calendar
          </a>
        )
      }
    </div>

    {/* Facts */}
    <dl class="mt-6 divide-y divide-border border-y border-border">
      {
        facts.map((f) => (
          <div class="flex gap-4 py-3">
            <dt class="eyebrow w-24 shrink-0 pt-0.5">{f.label}</dt>
            <dd class="min-w-0 flex-1 text-[0.9375rem] text-text">
              {f.href ? (
                <a
                  href={f.href}
                  target="_blank"
                  rel="noopener"
                  class="break-words text-accent transition-colors hover:underline"
                >
                  {f.value}
                </a>
              ) : (
                f.value
              )}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</Layout>

<script>
  import { initConferencePage } from "../../scripts/conf";
  document.addEventListener("astro:page-load", initConferencePage);
</script>
