---
import Layout from "../layouts/Layout.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import ConferenceCard from "../components/ConferenceCard.astro";
import SegToggle from "../components/SegToggle.astro";
import TzToggle from "../components/TzToggle.astro";
import { byDeadline, allConferences } from "../lib/deadlines";
import { buildCalendarEvents } from "../lib/calendar";
import { types } from "../data/conferences";

// Calendar events, baked into the page as JSON for scripts/calendar.ts.
const eventsJson = JSON.stringify(buildCalendarEvents(allConferences)).replace(
  /</g,
  "\\u003c",
);
---

<Layout>
  {/* Controls live in the sticky header bar so filtering/timezone/view stay
      reachable while scrolling. */}
  <div slot="toolbar" class="flex flex-wrap items-center gap-2">
    <SegToggle
      name="view"
      label="View"
      options={[
        { value: "list", title: "Countdowns" },
        { value: "calendar", title: "Calendar" },
      ]}
    >
      <svg slot="a" class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"></path></svg>
      <svg slot="b" class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v3M16 2v3M3.5 9h17M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"></path></svg>
    </SegToggle>

    <TzToggle />

    <CategoryFilter showPastToggle={true} />
  </div>

  {/* ---------------- List view ---------------- */}
  <div id="view-list">
    <section id="list" class="space-y-3">
      {byDeadline.map((c) => <ConferenceCard conf={c} />)}
    </section>
    <div id="empty-state" hidden class="py-20 text-center">
      <p class="text-text-2">No conferences match your filters.</p>
      <button
        type="button"
        data-show-all
        class="mt-3 rounded-full border border-border px-4 py-1.5 text-sm text-text transition-colors hover:bg-surface"
      >
        Show all
      </button>
    </div>
  </div>

  {/* ---------------- Calendar view ---------------- */}
  <div id="view-calendar" hidden>
    <div class="mt-6 flex items-center justify-center gap-5">
      <button data-cal-prev type="button" aria-label="Previous year" class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <span data-cal-year class="font-display text-[1.75rem] font-[520] tabular-nums text-text">—</span>
      <button data-cal-next type="button" aria-label="Next year" class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
    </div>
    <div data-cal-grid class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
    <div class="mt-10 flex flex-wrap gap-x-4 gap-y-2 text-xs text-text-3">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-2 w-2 rounded-full" style="background: var(--color-danger)"></span>Deadline
      </span>
      {
        types.map((t) => (
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-2 w-2 rounded-full" style={`background:${t.color}`} />
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  <script type="application/json" id="cal-data" set:html={eventsJson} is:inline></script>
</Layout>

<script>
  import { initApp } from "../scripts/app";
  document.addEventListener("astro:page-load", initApp);
</script>
