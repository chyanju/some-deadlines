---
import Layout from "../layouts/Layout.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import ConferenceCard from "../components/ConferenceCard.astro";
import IconToggle from "../components/IconToggle.astro";
import { byDeadline } from "../lib/deadlines";
---

<Layout>
  {/* Controls live in the sticky header bar so detail/timezone/filter stay
      reachable while scrolling. */}
  <div slot="toolbar" class="flex flex-wrap items-center gap-1 sm:gap-2">
    <IconToggle
      toggle="mode"
      iconInactive="telescope"
      iconActive="bird"
      label="Toggle detail (simple / complex)"
      title="Detail: simple / complex"
    />
    <IconToggle
      toggle="tz"
      iconInactive="clock"
      iconActive="globe"
      label="Toggle deadline time zone (Local / Anywhere on Earth)"
      title="Time zone: Local / AoE"
    />
    <CategoryFilter showPastToggle={true} />
  </div>

  <section id="list" class="space-y-3">
    {byDeadline.map((c) => <ConferenceCard conf={c} />)}
  </section>
  <div id="empty-state" hidden class="py-20 text-center">
    <p class="text-text-2">No conferences match your filters.</p>
    <button
      type="button"
      data-show-all
      class="mt-3 rounded-full border border-border px-4 py-1.5 text-sm text-text transition-colors hover:bg-surface"
    >
      Show all
    </button>
  </div>
</Layout>

<script>
  import { initApp } from "../scripts/app";
  document.addEventListener("astro:page-load", initApp);
</script>
