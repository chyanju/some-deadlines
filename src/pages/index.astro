---
import Layout from "../layouts/Layout.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import ConferenceCard from "../components/ConferenceCard.astro";
import { byDeadline } from "../lib/deadlines";
---

<Layout>
  <section class="pb-8">
    <h1
      class="font-display text-[clamp(2.25rem,5vw,3rem)] leading-[1.08] font-[520] tracking-[-0.022em] text-text"
    >
      Conference Deadlines
    </h1>
    <p class="mt-3 max-w-xl text-[1.0625rem] leading-relaxed text-text-2">
      Live countdowns to academic conference deadlines, shown in your local
      (<span class="local-tz">local</span>) time. Subscribe via
      <a
        href="/some-deadlines.ics"
        class="text-accent transition-colors hover:underline">.ics</a
      >.
    </p>
  </section>

  <div class="border-t border-border pt-6">
    <CategoryFilter />
  </div>

  <section id="upcoming" class="mt-6 space-y-3">
    {byDeadline.map((c) => <ConferenceCard conf={c} />)}
  </section>

  <h2
    id="past-heading"
    class="font-display mt-16 mb-4 border-t border-border pt-10 text-[1.75rem] font-[500] tracking-[-0.015em] text-text-2"
  >
    Past deadlines
  </h2>
  <section id="past" class="space-y-2"></section>
</Layout>

<script>
  import { initCountdowns } from "../scripts/countdown";
  import { initFilter } from "../scripts/filter";

  function init() {
    initCountdowns();
    initFilter((subs) => {
      const set = new Set(subs);
      for (const el of document.querySelectorAll<HTMLElement>("[data-conf]")) {
        const cs = (el.dataset.subs ?? "").split(",").filter(Boolean);
        el.hidden = !cs.some((s) => set.has(s));
      }
      const past = document.getElementById("past");
      const heading = document.getElementById("past-heading");
      if (past && heading) {
        const anyVisible = Array.from(
          past.querySelectorAll<HTMLElement>("[data-conf]"),
        ).some((e) => !e.hidden);
        heading.hidden = !anyVisible;
      }
    });
  }

  document.addEventListener("astro:page-load", init);
</script>
