---
import Layout from "../layouts/Layout.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import ConferenceCard from "../components/ConferenceCard.astro";
import TzToggle from "../components/TzToggle.astro";
import { byDeadline, allConferences, gcalEventUrl } from "../lib/deadlines";
import { types } from "../data/conferences";

// Calendar events (deadline = red/danger, conference span = category color).
const events = allConferences.flatMap((c) => {
  const out: Array<Record<string, unknown>> = [];
  if (!c.isTba) {
    const d = c.deadline.slice(0, 10);
    out.push({ id: c.id, title: `${c.title} ${c.year}`, kind: "deadline", from: d, to: d, color: "var(--color-danger)", subs: c.subs, place: c.place, dateLabel: c.date });
  }
  if (c.start && c.end) {
    out.push({ id: c.id, title: `${c.title} ${c.year}`, kind: "conference", from: c.start, to: c.end, color: c.categories[0]?.color ?? "#9ca3af", subs: c.subs, place: c.place, dateLabel: c.date });
  }
  return out;
});
const eventsJson = JSON.stringify(events).replace(/</g, "\\u003c");

// Drawer detail data.
const confData = allConferences.map((c) => ({
  id: c.id, title: c.title, year: c.year, full_name: c.full_name ?? "",
  link: c.link, place: c.place, date: c.date,
  paperslink: c.paperslink ?? "", pwclink: c.pwclink ?? "",
  deadlineMs: c.deadlineMs, absMs: c.absDeadlineMs,
  confTz: c.deadlineInConfTz, absConfTz: c.absInConfTz,
  dlShort: c.deadlineShort, absShort: c.absShort,
  cats: c.categories.map((t) => ({ sub: t.sub, name: t.name, color: t.color })),
  gcal: gcalEventUrl(c),
}));
const confJson = JSON.stringify(confData).replace(/</g, "\\u003c");
---

<Layout>
  {/* Controls live in the sticky header bar so filtering/timezone/view stay
      reachable while scrolling. */}
  <div slot="toolbar" class="flex flex-wrap items-center gap-2">
    <div class="tbar-seg" role="group" aria-label="View">
      <button type="button" data-view-btn="list" title="Countdowns" aria-label="Countdowns">
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"></path></svg>
      </button>
      <button type="button" data-view-btn="calendar" title="Calendar" aria-label="Calendar">
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v3M16 2v3M3.5 9h17M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"></path></svg>
      </button>
    </div>

    <TzToggle />

    <CategoryFilter showPastToggle={true} />
  </div>

  {/* ---------------- List view ---------------- */}
  <div id="view-list">
    <section id="list" class="space-y-3">
      {byDeadline.map((c) => <ConferenceCard conf={c} />)}
    </section>
  </div>

  {/* ---------------- Calendar view ---------------- */}
  <div id="view-calendar" hidden>
    <div class="mt-6 flex items-center justify-center gap-5">
      <button data-cal-prev type="button" aria-label="Previous year" class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <span data-cal-year class="font-display text-[1.75rem] font-[520] tabular-nums text-text">—</span>
      <button data-cal-next type="button" aria-label="Next year" class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
    </div>
    <div data-cal-grid class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
    <div class="mt-10 flex flex-wrap gap-x-4 gap-y-2 text-xs text-text-3">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-2 w-2 rounded-full" style="background: var(--color-danger)"></span>Deadline
      </span>
      {
        types.map((t) => (
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-2 w-2 rounded-full" style={`background:${t.color}`} />
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  {/* ---------------- Detail drawer ---------------- */}
  <div id="drawer" hidden class="fixed inset-0 z-40">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex justify-center overflow-auto p-4">
      <div
        id="drawer-panel"
        class="card relative mt-[6vh] mb-8 h-fit w-full max-w-xl p-6"
      >
      </div>
    </div>
  </div>

  <script type="application/json" id="cal-data" set:html={eventsJson} is:inline></script>
  <script type="application/json" id="conf-data" set:html={confJson} is:inline></script>
</Layout>

<script>
  import { initApp } from "../scripts/app";
  document.addEventListener("astro:page-load", initApp);
</script>
