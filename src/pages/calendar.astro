---
import Layout from "../layouts/Layout.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import { allConferences } from "../lib/deadlines";
import { types } from "../data/conferences";

const events = allConferences.flatMap((c) => {
  const out: Array<Record<string, unknown>> = [];
  if (!c.isTba) {
    const d = c.deadline.slice(0, 10);
    out.push({
      id: c.id,
      title: `${c.title} ${c.year}`,
      kind: "deadline",
      from: d,
      to: d,
      color: "var(--color-danger)",
      subs: c.subs,
      place: c.place,
      dateLabel: c.date,
    });
  }
  if (c.start && c.end) {
    out.push({
      id: c.id,
      title: `${c.title} ${c.year}`,
      kind: "conference",
      from: c.start,
      to: c.end,
      color: c.categories[0]?.color ?? "#9ca3af",
      subs: c.subs,
      place: c.place,
      dateLabel: c.date,
    });
  }
  return out;
});

const eventsJson = JSON.stringify(events).replace(/</g, "\\u003c");
---

<Layout title="Calendar">
  <CategoryFilter />

  <div class="mt-6 flex items-center justify-center gap-5">
    <button
      data-cal-prev
      type="button"
      aria-label="Previous year"
      class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
    </button>
    <span data-cal-year class="font-display text-[1.75rem] font-[520] tabular-nums text-text">—</span>
    <button
      data-cal-next
      type="button"
      aria-label="Next year"
      class="rounded-md p-1.5 text-text-3 transition-colors hover:bg-surface hover:text-text disabled:opacity-30"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
    </button>
  </div>

  <div
    data-cal-grid
    class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
  </div>

  <div class="mt-10 flex flex-wrap gap-x-4 gap-y-2 text-xs text-text-3">
    <span class="inline-flex items-center gap-1.5">
      <span
        class="inline-block h-2 w-2 rounded-full"
        style="background: var(--color-danger)"></span>Deadline
    </span>
    {
      types.map((t) => (
        <span class="inline-flex items-center gap-1.5">
          <span
            class="inline-block h-2 w-2 rounded-full"
            style={`background:${t.color}`}
          />
          {t.name}
        </span>
      ))
    }
  </div>

  <script type="application/json" id="cal-data" set:html={eventsJson} is:inline
  ></script>
</Layout>

<script>
  import { initCalendar } from "../scripts/calendar";
  document.addEventListener("astro:page-load", initCalendar);
</script>
