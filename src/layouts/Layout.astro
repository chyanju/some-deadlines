---
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/geist";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = site.description } = Astro.props;
const fullTitle = title ? `${title} · ${site.title}` : site.title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="icon" href="/favicon.png" />

    {/* Apply theme / detail / time-zone classes before first paint to avoid a
        flash (localStorage only — mirrors theme.ts, mode.ts, tz.ts). */}
    <script is:inline>
      (() => {
        const ls = localStorage;
        const h = document.documentElement;
        const t = ls.getItem("theme");
        h.classList.toggle(
          "dark",
          t === "dark" ||
            (!t && window.matchMedia("(prefers-color-scheme: dark)").matches),
        );
        h.classList.toggle("simple", ls.getItem("some-deadlines-mode") === "simple");
        h.classList.toggle("aoe", ls.getItem("some-deadlines-tz") === "aoe");
      })();
    </script>

    <ClientRouter />

    {
      site.gaId && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${site.gaId}`}
          />
          <script is:inline define:vars={{ gaId: site.gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaId);
          </script>
        </>
      )
    }
  </head>
  <body class="flex min-h-screen flex-col transition-colors">
    {/* Liquid-glass edge refraction filter (used by backdrop-filter on glass chrome). */}
    <svg
      aria-hidden="true"
      focusable="false"
      width="0"
      height="0"
      style="position:absolute"
    >
      <filter
        id="liquid-glass"
        x="-20%"
        y="-20%"
        width="140%"
        height="140%"
        color-interpolation-filters="sRGB"
      >
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.009 0.011"
          numOctaves="2"
          seed="7"
          result="noise"
        />
        <feGaussianBlur in="noise" stdDeviation="2.2" result="noiseBlur" />
        <feDisplacementMap
          in="SourceGraphic"
          in2="noiseBlur"
          scale="26"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>
    </svg>
    <Header>
      <slot name="toolbar" slot="toolbar" />
    </Header>
    <main class="mx-auto w-full max-w-3xl flex-1 px-5 py-8">
      <slot />
    </main>

    <script>
      import { initTheme } from "../scripts/theme";
      initTheme();
    </script>
  </body>
</html>
